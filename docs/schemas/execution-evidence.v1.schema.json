  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "agentic-qa.execution-evidence.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "run_id": {
      "title": "Run Id",
      "type": "string"
    },
    "source_cases_path": {
      "title": "Source Cases Path",
      "type": "string"
    },
    "source_cases_schema_version": {
      "title": "Source Cases Schema Version",
      "type": "string"
    },
    "started_at": {
      "format": "date-time",
      "title": "Started At",
      "type": "string"
    },
    "completed_at": {
      "format": "date-time",
      "title": "Completed At",
      "type": "string"
    },
    "environment": {
      "$ref": "#/$defs/ExecutionEnvironment"
    },
    "summary": {
      "$ref": "#/$defs/ExecutionSummary"
    },
    "cases": {
      "items": {
        "$ref": "#/$defs/CaseExecutionEvidence"
      },
      "minItems": 1,
      "title": "Cases",
      "type": "array"
    }
  },
  "required": [
    "schema_version",
    "run_id",
    "source_cases_path",
    "source_cases_schema_version",
    "started_at",
    "completed_at",
    "environment",
    "summary",
    "cases"
  ],
  "title": "ExecutionEvidence",
  "type": "object"
}
