FEISHU_APP_ID=
FEISHU_APP_SECRET=

DEFAULT_LLM_PROVIDER=deepseek

# DeepSeek（OpenAI 兼容 + Anthropic 兼容）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# Claude（通过 DeepSeek Anthropic 兼容端点）
CLAUDE_API_KEY=
CLAUDE_BASE_URL=https://api.deepseek.com/anthropic
CLAUDE_MODEL=claude-sonnet-4-20250514

OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_MODEL=

# RAG 配置
RAG_ENABLED=true
RAG_TOP_K=5
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
RAG_EMBEDDING_MODEL=text-embedding-3-small
RAG_EMBEDDING_DIM=1536
RAG_VECTOR_STORE=faiss
RAG_INDEX_DIR=.rag_index
RAG_KNOWLEDGE_PATHS=knowledge/qa-methodology,knowledge/project-rules,knowledge/templates
