# 敏感值只保存在环境变量中，不要把真实 Token、密钥或密码提交到仓库。

# DeepSeek / OpenAI-compatible 模型配置。
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
AGENTIC_QA_MODEL_API_KEY_ENV=DEEPSEEK_API_KEY
AGENTIC_QA_MODEL_FLASH=deepseek-v4-flash
AGENTIC_QA_MODEL_PRO=deepseek-v4-pro
AGENTIC_QA_MODEL=
AGENTIC_QA_MODEL_BASE_URL=https://api.deepseek.com
AGENTIC_QA_MODEL_TIMEOUT_SECONDS=180
AGENTIC_QA_MODEL_MAX_OUTPUT_TOKENS=16384

# ExecutionProfile 使用的测试环境地址，不得填写生产环境地址。
AGENTIC_QA_BASE_URL=

# GitHub MCP 预留变量；当前运行时尚未消费。
GITHUB_TOKEN=
AGENTIC_QA_GITHUB_TOKEN_ENV=GITHUB_TOKEN

# 远程 RAG Provider 配置；默认本地词法检索不会读取这些值。
RAG_API_KEY=
AGENTIC_QA_RAG_API_KEY_ENV=RAG_API_KEY
AGENTIC_QA_RAG_BASE_URL=

# PostgreSQL checkpoint 与只读测试数据源共享连接环境变量，但使用独立配置对象。
PG_LOCAL_HOST=localhost
PG_LOCAL_PORT=5432
PG_LOCAL_DATABASE=postgres
PG_LOCAL_USER=postgres
PG_LOCAL_PASSWORD=
