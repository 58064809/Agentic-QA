# DeepSeek is auto-configured when this existing environment variable is set.
DEEPSEEK_API_KEY=

# Optional routing overrides. AGENTIC_QA_MODEL pins both tiers to one model.
AGENTIC_QA_MODEL_FLASH=deepseek-v4-flash
AGENTIC_QA_MODEL_PRO=deepseek-v4-pro
# AGENTIC_QA_MODEL=
# AGENTIC_QA_MODEL_BASE_URL=https://api.deepseek.com
# AGENTIC_QA_MODEL_API_KEY_ENV=DEEPSEEK_API_KEY

# Explicit test environment used by ExecutionProfile
AGENTIC_QA_BASE_URL=
